# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# Token del bot obtenido desde @BotFather en Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API Key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here
MODEL_NAME=google/gemini-flash-1.5

# ID del grupo de Telegram (negativo para grupos, ej: -1001234567890)
# Obtenerlo: añade @userinfobot al grupo y escribe /start
GROUP_ID=-1001234567890

# URL pública HTTPS del dashboard (requerida para el Mini App de Telegram)
# Para desarrollo local instala ngrok (https://ngrok.com) y ejecuta:
#   ngrok http 8000
# Copia la URL https://xxxx.ngrok-free.app y únela aquí:
WEBAPP_URL=https://xxxx.ngrok-free.app

# Configuración del Dashboard
PORT=8000


